# ─────────────────────────────────────────────────────────────
#  Contact form email (Nodemailer / SMTP)
#  Copy this file to `.env.local` for local dev, and add the same
#  variables in Vercel → Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# SMTP server (example uses Gmail; see README for an App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-sending-address@gmail.com
# For Gmail this must be a 16-char App Password, NOT your login password
SMTP_PASS=your-app-password

# Where contact messages are delivered
CONTACT_TO=guptharshal.hg@gmail.com
# Optional "from" address (defaults to SMTP_USER)
CONTACT_FROM=your-sending-address@gmail.com
